# Copy to `.env` in the repo root (`.env` is gitignored). Do not commit secrets.

# --- Hugging Face / GitHub (collect, convmerge manifest auth, worker model download) ---
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=
GITHUB_TOKEN=

# --- Refine / HF staging (optional) ---
HF_DATASET_REPO_NAME=

# --- RunPod classify (batch client → worker HTTP) ---
RUNPOD_API_KEY=
LACUNA_DATA_API_BASE=
LACUNA_DATA_API_KEY=
# Optional tuning; additional LACUNA_DATA_CLASSIFY_* knobs live in
# pipeline/tasks/classifiers/runpod_batch_classify.py and PIPELINE.md.
LACUNA_DATA_CLASSIFY_POD_COUNT=
LACUNA_DATA_CLASSIFY_BATCH_SIZE=

# --- Anthropic (optional: refine_llm / identity eval / assistant rewrite) ---
ANTHROPIC_API_KEY=

# --- RunPod GPU worker (scripts/data_worker_api.py) — optional local / pod tuning ---
CLASSIFY_MODEL=
PRELOAD_CLASSIFY=
LACUNA_DATA_VERBOSE_ERRORS=
